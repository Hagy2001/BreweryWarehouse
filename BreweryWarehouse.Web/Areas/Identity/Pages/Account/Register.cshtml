@page
@model RegisterModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — The Garden Brewery</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bw-auth-page">
    <div class="bw-auth-card">
        <div class="bw-auth-card__logo">
            <img src="~/images/logo.svg" alt="The Garden Brewery" style="fill: var(--bw-accent); height: 60px;" />
        </div>
        <h1 class="bw-auth-card__title">Create Account</h1>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="bw-form-error"></div>

            <div class="bw-form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="bw-form-control" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="bw-form-hint bw-form-hint--error"></span>
            </div>

            <div class="bw-form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="bw-form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="bw-form-hint bw-form-hint--error"></span>
            </div>

            <div class="bw-form-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="bw-form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="bw-form-hint bw-form-hint--error"></span>
            </div>

            <div class="bw-form-group">
                <label asp-for="Input.OIB">OIB <span class="bw-form-hint">(11 digits)</span></label>
                <input asp-for="Input.OIB" class="bw-form-control" maxlength="11" />
                <span asp-validation-for="Input.OIB" class="bw-form-hint bw-form-hint--error"></span>
            </div>

            <div class="bw-form-group">
                <label asp-for="Input.JMBG">JMBG <span class="bw-form-hint">(13 digits)</span></label>
                <input asp-for="Input.JMBG" class="bw-form-control" maxlength="13" />
                <span asp-validation-for="Input.JMBG" class="bw-form-hint bw-form-hint--error"></span>
            </div>

            <button type="submit" class="bw-btn bw-btn--primary bw-btn--full">Register</button>
        </form>

        <p class="bw-auth-card__footer">
            Already have an account?
            <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
        </p>
    </div>
</body>
</html>
