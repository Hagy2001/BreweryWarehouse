@page
@model ExternalLoginModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Complete Registration — BreweryWarehouse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bw-login-body">
    <main class="bw-login-main" role="main">
        <section class="bw-login-card" aria-label="Complete registration">
            <img src="~/images/logo.svg" alt="The Garden Brewery" class="bw-login-logo" />
            <h1 class="bw-login-brand">BreweryWarehouse</h1>
            <p class="bw-login-subtitle">Signed in via @Model.ProviderDisplayName. Complete your profile to continue.</p>

            <form method="post" asp-page-handler="Confirmation" class="bw-login-form">
                <div asp-validation-summary="ModelOnly" class="bw-validation-summary"></div>
                <input type="hidden" asp-for="ProviderDisplayName" />

                <div class="bw-field-group">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="bw-input" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="bw-field-error"></span>
                </div>

                <div class="bw-field-group">
                    <label asp-for="Input.OIB">OIB <span class="bw-field-hint">(11 digits)</span></label>
                    <input asp-for="Input.OIB" class="bw-input" maxlength="11" />
                    <span asp-validation-for="Input.OIB" class="bw-field-error"></span>
                </div>

                <div class="bw-field-group">
                    <label asp-for="Input.JMBG">JMBG <span class="bw-field-hint">(13 digits)</span></label>
                    <input asp-for="Input.JMBG" class="bw-input" maxlength="13" />
                    <span asp-validation-for="Input.JMBG" class="bw-field-error"></span>
                </div>

                <button type="submit" class="bw-login-btn">Complete Registration</button>
            </form>

            <p class="bw-login-subtitle bw-login-footer">
                <a asp-page="./Login">Back to sign in</a>
            </p>
        </section>
    </main>
</body>
</html>
