@page
@model LoginModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — BreweryWarehouse</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bw-login-body">
    <main class="bw-login-main" role="main">
        <section class="bw-login-card" aria-label="Sign in">
            <h1 class="bw-login-brand">BreweryWarehouse</h1>
            <p class="bw-login-subtitle">Warehouse management system</p>

            <form method="post" class="bw-login-form">
                <div asp-validation-summary="ModelOnly" class="bw-validation-summary"></div>

                <div class="bw-field-group">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" class="bw-input" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="bw-field-error"></span>
                </div>

                <div class="bw-field-group">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" class="bw-input" type="password" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="bw-field-error"></span>
                </div>

                <button type="submit" class="bw-login-btn">Sign In</button>
            </form>

            <div style="display:flex; align-items:center; gap:0.75rem; margin:1rem 0 0.85rem;">
                <span style="background:var(--bw-border); flex:1; height:1px;"></span>
                <span class="bw-login-subtitle" style="margin:0; font-size:0.8rem; letter-spacing:0.08em; text-transform:uppercase;">or</span>
                <span style="background:var(--bw-border); flex:1; height:1px;"></span>
            </div>

            <form method="post" asp-page-handler="ExternalLogin">
                <input type="hidden" name="provider" value="Google" />
                <button type="submit" class="bw-btn bw-btn-ghost" style="width:100%; display:flex; align-items:center; justify-content:center; padding:0.5rem;" aria-label="Sign in with Google">
                    <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.16v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.16C1.43 8.55 1 10.22 1 12s.43 3.45 1.16 4.93l3.68-2.84z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.16 7.07l3.68 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                </button>
            </form>

            <p class="bw-login-subtitle" style="margin-top:1rem; margin-bottom:0;">
                No account?
                <a asp-area="Identity" asp-page="/Account/Register">Register</a>
            </p>
        </section>
    </main>
</body>
</html>
</html>
