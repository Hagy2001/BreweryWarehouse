@model BreweryWarehouse.Web.Models.DatePickerModel
@{
    var culture = ViewData["Culture"]?.ToString() ?? "hr";
    var isoValue = Model.Value?.ToString("yyyy-MM-dd");
}

<div class="bw-datepicker bw-field-group" data-culture="@culture">
    <label for="visible-@Model.FieldName" class="bw-form-label">@Model.Label</label>

    <div class="bw-datepicker__input-wrapper">
        <input type="text"
               id="visible-@Model.FieldName"
               class="bw-datepicker__display bw-input"
               autocomplete="off"
               placeholder="@(culture == "hr" ? "dd.mm.yyyy" : "mm/dd/yyyy")"
               @(Model.IsRequired ? "required" : "") />

        <button type="button" class="bw-datepicker__toggle" aria-label="Toggle calendar" tabindex="-1">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
        </button>

        <input type="hidden"
               name="@Model.FieldName"
               id="@Model.FieldName"
               value="@isoValue"
               class="bw-datepicker__hidden" />
    </div>

    <div class="bw-datepicker-calendar" hidden>
        <div class="bw-datepicker__header">
            <button type="button" class="bw-datepicker__prev" aria-label="Previous month" tabindex="-1">&lt;</button>
            <button type="button" class="bw-datepicker__month-year-btn" aria-label="Select year"></button>
            <button type="button" class="bw-datepicker__next" aria-label="Next month" tabindex="-1">&gt;</button>
        </div>
        <div class="bw-datepicker__grid"></div>
        <div class="bw-datepicker__year-picker" hidden>
            <div class="bw-datepicker__year-header">
                <button type="button" class="bw-datepicker__prev-decade" aria-label="Previous decade" tabindex="-1">&lt;&lt;</button>
                <span class="bw-datepicker__decade-label"></span>
                <button type="button" class="bw-datepicker__next-decade" aria-label="Next decade" tabindex="-1">&gt;&gt;</button>
            </div>
            <div class="bw-datepicker__year-grid"></div>
        </div>
    </div>

    @Html.ValidationMessage(Model.FieldName, null, new { @class = "bw-field-error" })
</div>