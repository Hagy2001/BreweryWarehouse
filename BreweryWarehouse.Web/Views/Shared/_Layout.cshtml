<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BreweryWarehouse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{ 
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string GetActive(string controller) => currentController == controller ? "active" : string.Empty;
        string? GetAriaCurrent(string controller) => currentController == controller ? "page" : null;
    }

    <div class="bw-shell">
        <aside class="bw-sidebar" aria-label="Primary">
            <a asp-controller="Home" asp-action="Index" class="bw-brand">BREWERYWAREHOUSE</a>
            <nav class="bw-nav">
                <a asp-controller="Home" asp-action="Index" class="@GetActive("Home")" aria-current="@GetAriaCurrent("Home")">Home</a>
                <a asp-controller="BeerStyle" asp-action="Index" class="@GetActive("BeerStyle")" aria-current="@GetAriaCurrent("BeerStyle")">Beer Styles</a>
                <a asp-controller="Can" asp-action="Index" class="@GetActive("Can")" aria-current="@GetAriaCurrent("Can")">Cans</a>
                <a asp-controller="Keg" asp-action="Index" class="@GetActive("Keg")" aria-current="@GetAriaCurrent("Keg")">Kegs</a>
                <a asp-controller="WarehouseLocation" asp-action="Index" class="@GetActive("WarehouseLocation")" aria-current="@GetAriaCurrent("WarehouseLocation")">Locations</a>
                <a asp-controller="StockEntry" asp-action="Index" class="@GetActive("StockEntry")" aria-current="@GetAriaCurrent("StockEntry")">Stock</a>
                <a asp-controller="Employee" asp-action="Index" class="@GetActive("Employee")" aria-current="@GetAriaCurrent("Employee")">Employees</a>
            </nav>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="bw-sidebar-footer" aria-label="Active user">
                    <div class="bw-sidebar-footer__user">@User.Identity.Name</div>
                    <form method="post" asp-controller="Auth" asp-action="Logout" class="bw-signout-form">
                        <button type="submit" class="bw-signout-btn bw-signout-btn--full">Sign Out</button>
                    </form>
                </div>
            }
        </aside>

        <main class="bw-content" role="main">
            <div class="bw-content-inner">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="bw-footer">
        <div>
            &copy; 2026 BreweryWarehouse
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
