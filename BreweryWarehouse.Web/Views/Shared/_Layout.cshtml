<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BreweryWarehouse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="bw-shell">
        <aside class="bw-sidebar" aria-label="Primary">
            <a asp-controller="Home" asp-action="Index" class="bw-brand">BREWERYWAREHOUSE</a>
            <nav class="bw-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="BeerStyle" asp-action="Index">Beer Styles</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="cans">Cans</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="kegs">Kegs</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="locations">Locations</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="stock">Stock</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="employees">Employees</a>
            </nav>
        </aside>

        <main class="bw-content" role="main">
            <header class="bw-topbar">
                <h2 class="bw-topbar__title">@ViewData["Title"]</h2>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="bw-topbar__actions">
                        <span class="bw-topbar__user">@User.Identity.Name</span>
                        <form method="post" asp-controller="Auth" asp-action="Logout" class="bw-signout-form">
                            <button type="submit" class="bw-signout-btn">Sign Out</button>
                        </form>
                    </div>
                }
            </header>

            <div class="bw-content-inner">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="bw-footer">
        <div>
            &copy; 2026 BreweryWarehouse
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
