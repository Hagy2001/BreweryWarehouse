                <a asp-controller="WarehouseLocation" asp-action="Index" class="@GetActive("WarehouseLocation")" aria-current="@GetAriaCurrent("WarehouseLocation")">Locations</a>
                <a asp-controller="StockEntry" asp-action="Index" class="@GetActive("StockEntry")" aria-current="@GetAriaCurrent("StockEntry")">Stock</a>
                <a asp-controller="Employee" asp-action="Index" class="@GetActive("Employee")" aria-current="@GetAriaCurrent("Employee")">Employees</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="UserManagement" asp-action="Index" class="@GetActive("UserManagement")" aria-current="@GetAriaCurrent("UserManagement")">User Roles</a>
                }
            </nav>

            <partial name="_LoginPartial" />
        </aside>

        <main class="bw-content" role="main">
            <div class="bw-content-inner">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="bw-footer">
        <div>
            &copy; 2026 BreweryWarehouse
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/load-animation.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
