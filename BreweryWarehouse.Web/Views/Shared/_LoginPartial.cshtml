@using Microsoft.AspNetCore.Identity
@inject SignInManager<BreweryWarehouse.Web.Models.AppUser> SignInManager
@inject UserManager<BreweryWarehouse.Web.Models.AppUser>   UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="bw-sidebar-footer">
        <div class="bw-sidebar-footer__user">@UserManager.GetUserName(User)</div>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
            <button type="submit" class="bw-btn bw-btn-ghost">Logout</button>
        </form>
    </div>
}
else
{
    <div class="bw-sidebar-footer">
        <a asp-area="Identity" asp-page="/Account/Login" class="bw-btn bw-btn-ghost">Login</a>
    </div>
}
