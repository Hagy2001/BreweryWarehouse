@model BreweryWarehouse.Web.Models.WarehouseLocationEditModel

@{
    ViewData["Title"] = "Edit Location";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="WarehouseLocation" asp-action="Index">Locations</a></li>
        <li><a asp-action="Details" asp-route-id="@Model.Id">@Model.LocationCode</a></li>
        <li aria-current="page">Edit</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Edit @Model.LocationCode</h1>
</div>

<div class="detail-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_CreateOrEdit" model="@(new BreweryWarehouse.Web.Models.WarehouseLocationCreateModel
        {
            LocationCode = Model.LocationCode,
            Aisle = Model.Aisle,
            Shelf = Model.Shelf,
            MaxCapacity = Model.MaxCapacity,
            Description = Model.Description
        })" />
    </form>
</div>
