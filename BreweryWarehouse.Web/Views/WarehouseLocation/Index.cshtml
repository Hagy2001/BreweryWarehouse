@model List<BreweryWarehouse.Model.WarehouseLocation>

@{
    ViewData["Title"] = "Warehouse Locations";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Locations</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Warehouse Locations</h1>
    <div class="bw-page-actions">
        <a asp-controller="WarehouseLocation" asp-action="Create" class="bw-btn bw-btn-primary">New Location</a>
    </div>
</div>

<div class="bw-toolbar">
    <input type="text" id="locationSearch" class="bw-input" placeholder="Search by location code or aisle" autocomplete="off" />
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>Location Code</th>
                <th>Aisle</th>
                <th>Shelf</th>
                <th>Capacity Used</th>
                <th>Fill % bar</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody id="locationTableBody">
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var location in Model)
                {
                    int used = location.StockEntries.Sum(entry => entry.Quantity);
                    int max = location.MaxCapacity;
                    bool isOverfill = max > 0 && used > max;
                    double percentage = max > 0 ? (double)used / max * 100 : 0;
                    int bucketedPercentage = (int)(Math.Round(Math.Min(100.0, percentage) / 5.0) * 5);

                    <tr>
                        <td>@location.LocationCode</td>
                        <td>@location.Aisle</td>
                        <td>@location.Shelf</td>
                        <td>@used / @max</td>
                        <td>
                            <div class="location-track location-track--index" aria-label="@used out of @max used">
                                <div class="location-fill @(isOverfill ? "location-fill--overfill" : "") bw-w-@bucketedPercentage"></div>
                            </div>
                        </td>
                        <td>
                            <a asp-controller="WarehouseLocation" asp-action="Details" asp-route-id="@location.Id" class="bw-pill-link">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            let searchTimer = null;
            const $searchInput = $('#locationSearch');
            const $tableBody = $('#locationTableBody');

            $searchInput.on('keyup', function () {
                clearTimeout(searchTimer);
                const query = $(this).val();

                searchTimer = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Search", "WarehouseLocation")',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            $tableBody.empty();

                            if (!data || data.length === 0) {
                                $tableBody.append('<tr><td colspan="6">No results found.</td></tr>');
                                return;
                            }

                            data.forEach(function (item) {
                                const detailsUrl = '@Url.Action("Details", "WarehouseLocation", new { id = "__id__" })'.replace('__id__', item.id);
                                const overfillClass = item.isOverfill ? 'location-fill--overfill' : '';
                                const rowHtml = `
                                    <tr>
                                        <td>${item.locationCode}</td>
                                        <td>${item.aisle}</td>
                                        <td>${item.shelf}</td>
                                        <td>${item.used} / ${item.maxCapacity}</td>
                                        <td>
                                            <div class="location-track location-track--index" aria-label="${item.used} out of ${item.maxCapacity} used">
                                                <div class="location-fill ${overfillClass} bw-w-${item.bucketedPercentage}"></div>
                                            </div>
                                        </td>
                                        <td><a href="${detailsUrl}" class="bw-pill-link">Details</a></td>
                                    </tr>`;

                                $tableBody.append(rowHtml);
                            });
                        }
                    });
                }, 300);
            });
        });
    </script>
}
