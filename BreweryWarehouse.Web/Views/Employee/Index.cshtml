@model List<BreweryWarehouse.Model.Employee>

@{
    ViewData["Title"] = "Employees";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Employees</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Employees</h1>
    <div class="bw-page-actions">
        <a asp-controller="Employee" asp-action="Create" class="bw-btn bw-btn-primary">New Employee</a>
    </div>
</div>

<div class="bw-toolbar">
    <input type="text" id="employeeSearch" class="bw-input" placeholder="Search by name or email" autocomplete="off" />
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Date Hired</th>
                <th>Status</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody id="employeeTableBody">
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.FirstName @emp.LastName</td>
                    <td>@Html.DisplayFor(modelItem => emp.Email)</td>
                    <td>@Html.DisplayFor(modelItem => emp.Role)</td>
                    <td>@emp.DateHired.ToString("dd MMM yyyy")</td>
                    <td>
                        @if (emp.IsActive)
                        {
                            <span class="bw-badge bw-badge--active">Active</span>
                        }
                        else
                        {
                            <span class="bw-badge bw-badge--inactive">Inactive</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="Employee" asp-action="Details" asp-route-id="@emp.Id" class="bw-pill-link">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            let searchTimer = null;
            const $searchInput = $('#employeeSearch');
            const $tableBody = $('#employeeTableBody');

            $searchInput.on('keyup', function () {
                clearTimeout(searchTimer);
                const query = $(this).val();

                searchTimer = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Search", "Employee")',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            $tableBody.empty();

                            if (!data || data.length === 0) {
                                $tableBody.append('<tr><td colspan="6">No results found.</td></tr>');
                                return;
                            }

                            data.forEach(function (item) {
                                const detailsUrl = '@Url.Action("Details", "Employee", new { id = "__id__" })'.replace('__id__', item.id);
                                const statusBadge = item.isActive
                                    ? '<span class="bw-badge bw-badge--active">Active</span>'
                                    : '<span class="bw-badge bw-badge--inactive">Inactive</span>';

                                const rowHtml = `
                                    <tr>
                                        <td>${item.firstName} ${item.lastName}</td>
                                        <td>${item.email}</td>
                                        <td>${item.role}</td>
                                        <td>${item.dateHiredDisplay}</td>
                                        <td>${statusBadge}</td>
                                        <td><a href="${detailsUrl}" class="bw-pill-link">Details</a></td>
                                    </tr>`;

                                $tableBody.append(rowHtml);
                            });
                        }
                    });
                }, 300);
            });
        });
    </script>
}
