@model BreweryWarehouse.Web.Models.EmployeeEditModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Edit Employee";
    ViewData["Culture"] = "hr";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Employee" asp-action="Index">Employees</a></li>
        <li><a asp-action="Details" asp-route-id="@Model.Id">@Model.FirstName @Model.LastName</a></li>
        <li aria-current="page">Edit</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Edit @Model.FirstName @Model.LastName</h1>
</div>

<div class="detail-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_CreateOrEdit" model="@(new BreweryWarehouse.Web.Models.EmployeeCreateModel
        {
            FirstName = Model.FirstName,
            LastName = Model.LastName,
            Email = Model.Email,
            Role = Model.Role,
            DateHired = Model.DateHired,
            IsActive = Model.IsActive
        })" />
        <div class="bw-field-group">
            <label class="bw-form-label" for="AppUserId">Linked Account</label>
            <select id="AppUserId" name="AppUserId" class="bw-input">
                <option value="">— No linked account —</option>
                @foreach (SelectListItem item in (SelectList)ViewBag.AppUsers)
                {
                    if (item.Selected)
                    {
                        <option value="@item.Value" selected="selected">@item.Text</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </div>
    </form>
</div>
