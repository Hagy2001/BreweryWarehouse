@model BreweryWarehouse.Web.Models.BeerStyleEditModel

@{
    ViewData["Title"] = "Edit Beer Style";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="BeerStyle" asp-action="Index">Beer Styles</a></li>
        <li aria-current="page">Edit: @Model.Name</li>
    </ol>
</nav>

<h1 class="bw-page-title">Edit Beer Style</h1>

<div class="detail-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <partial name="_CreateOrEdit" model="@(new BreweryWarehouse.Web.Models.BeerStyleCreateModel { Name = Model.Name, Description = Model.Description, AlcoholPercentage = Model.AlcoholPercentage, IBU = Model.IBU, ColorEBC = Model.ColorEBC, Category = Model.Category })" />
    </form>
</div>
