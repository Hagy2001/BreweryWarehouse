@model List<BreweryWarehouse.Model.BeerStyle>

@{
    ViewData["Title"] = "Beer Styles";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Beer Styles</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Beer Styles</h1>
    <div class="bw-page-actions">
        <a asp-action="Create" class="bw-btn bw-btn-primary">New Beer Style</a>
    </div>
</div>

<div class="bw-toolbar">
    <input type="text" id="beerStyleSearch" class="bw-input" placeholder="Search by beer style name" autocomplete="off" />
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Alcohol %</th>
                <th>IBU</th>
                <th>Color EBC</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody id="beerStyleTableBody">
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td><span class="bw-badge bw-badge--category">@item.Category.GetDescription()</span></td>
                        <td>@item.AlcoholPercentage.ToString("0.0")%</td>
                        <td>@Html.DisplayFor(modelItem => item.IBU)</td>
                        <td>@Html.DisplayFor(modelItem => item.ColorEBC)</td>
                        <td>
                            <a asp-controller="BeerStyle" asp-action="Details" asp-route-id="@item.Id" class="bw-pill-link">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            let searchTimer = null;
            const $searchInput = $('#beerStyleSearch');
            const $tableBody = $('#beerStyleTableBody');

            $searchInput.on('keyup', function () {
                clearTimeout(searchTimer);
                const query = $(this).val();

                searchTimer = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Search", "BeerStyle")',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            $tableBody.empty();

                            if (!data || data.length === 0) {
                                $tableBody.append('<tr><td colspan="6">No results found.</td></tr>');
                                return;
                            }

                            data.forEach(function (item) {
                                const detailsUrl = '@Url.Action("Details", "BeerStyle", new { id = "__id__" })'.replace('__id__', item.id);
                                const alcoholDisplay = Number(item.alcoholPercentage).toFixed(1) + '%';

                                const rowHtml = `
                                    <tr>
                                        <td>${item.name}</td>
                                        <td><span class="bw-badge bw-badge--category">${item.category}</span></td>
                                        <td>${alcoholDisplay}</td>
                                        <td>${item.ibu}</td>
                                        <td>${item.colorEBC}</td>
                                        <td><a href="${detailsUrl}" class="bw-pill-link">Details</a></td>
                                    </tr>`;

                                $tableBody.append(rowHtml);
                            });
                        }
                    });
                }, 300);
            });
        });
    </script>
}
