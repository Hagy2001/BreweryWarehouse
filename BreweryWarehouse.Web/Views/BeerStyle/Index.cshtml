@model List<BreweryWarehouse.Model.BeerStyle>

@{
    ViewData["Title"] = "Beer Styles";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Beer Styles</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Beer Styles</h1>
    <div class="bw-page-actions">
        <a asp-action="Create" class="bw-btn bw-btn-primary">New Beer Style</a>
    </div>
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model[0].Name)</th>
                <th>@Html.DisplayNameFor(model => model[0].Category)</th>
                <th>Alcohol %</th>
                <th>@Html.DisplayNameFor(model => model[0].IBU)</th>
                <th>@Html.DisplayNameFor(model => model[0].ColorEBC)</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Name)</td>
                    <td><span class="bw-badge bw-badge--category">@item.Category.GetDescription()</span></td>
                    <td>@item.AlcoholPercentage.ToString("0.0")%</td>
                    <td>@Html.DisplayFor(modelItem => item.IBU)</td>
                    <td>@Html.DisplayFor(modelItem => item.ColorEBC)</td>
                    <td>
                        <a asp-controller="BeerStyle" asp-action="Details" asp-route-id="@item.Id" class="bw-pill-link">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
