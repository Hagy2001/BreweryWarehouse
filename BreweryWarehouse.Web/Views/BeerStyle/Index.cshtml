@model List<BreweryWarehouse.Model.BeerStyle>

@{
    ViewData["Title"] = "Beer Styles";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Beer Styles</li>
    </ol>
</nav>

<h1 class="bw-page-title">Beer Styles</h1>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>ABV</th>
                <th>IBU</th>
                <th>Cans</th>
                <th>Kegs</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td><span class="bw-badge bw-badge--category">@item.Category.GetDescription()</span></td>
                    <td>@item.AlcoholPercentage.ToString("0.0")%</td>
                    <td>@item.IBU</td>
                    <td>@item.Cans.Count</td>
                    <td>@item.Kegs.Count</td>
                    <td>
                        <a asp-controller="BeerStyle" asp-action="Details" asp-route-id="@item.Id" class="bw-pill-link">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
