@model BreweryWarehouse.Web.Models.KegCreateModel

@{
    ViewData["Title"] = "New Keg";
    ViewData["Culture"] = "hr";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Keg" asp-action="Index">Kegs</a></li>
        <li aria-current="page">New Keg</li>
    </ol>
</nav>

<h1 class="bw-page-title">New Keg</h1>

<div class="detail-card">
    <div class="detail-card__header">
        <h2 class="detail-card__title">Keg Information</h2>
    </div>

    <form asp-action="Create" method="post" class="bw-form">
        @Html.AntiForgeryToken()
        <partial name="_CreateOrEdit" model="Model" />
    </form>
</div>
