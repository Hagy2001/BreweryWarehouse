@using BreweryWarehouse.Model
@model List<BreweryWarehouse.Model.Keg>

@{
    ViewData["Title"] = "Kegs";
    DateTime expiryThreshold = DateTime.Today.AddDays(30);
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Kegs</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Kegs</h1>
    <div class="bw-page-actions">
        <a asp-controller="Keg" asp-action="Create" class="bw-btn bw-btn-primary">New Keg</a>
    </div>
</div>

<div class="bw-toolbar">
    <input type="text" id="kegSearch" class="bw-input" placeholder="Search by SL code or beer style" autocomplete="off" />
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>SLCode</th>
                <th>Beer Style</th>
                <th>Volume</th>
                <th>Material</th>
                <th>Head Type</th>
                <th>Last Inspection</th>
                <th>Best Before</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody id="kegTableBody">
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="8">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var keg in Model)
                {
                    string rowClass = keg.BestBefore.Date <= expiryThreshold.Date ? "row-expiring" : string.Empty;
                    <tr class="@rowClass">
                        <td>@keg.SLCode</td>
                        <td>@(keg.BeerStyle?.Name ?? "-")</td>
                        <td>@keg.VolumeInLitres L</td>
                        <td>@keg.Material.GetDescription()</td>
                        <td>@keg.HeadType.GetDescription()</td>
                        <td>@keg.LastInspection.ToString("dd MMM yyyy")</td>
                        <td>@keg.BestBefore.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-controller="Keg" asp-action="Details" asp-route-id="@keg.Id" class="bw-pill-link">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            let searchTimer = null;
            const $searchInput = $('#kegSearch');
            const $tableBody = $('#kegTableBody');

            $searchInput.on('keyup', function () {
                clearTimeout(searchTimer);
                const query = $(this).val();

                searchTimer = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Search", "Keg")',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            $tableBody.empty();

                            if (!data || data.length === 0) {
                                $tableBody.append('<tr><td colspan="8">No results found.</td></tr>');
                                return;
                            }

                            const threshold = new Date();
                            threshold.setDate(threshold.getDate() + 30);

                            data.forEach(function (item) {
                                const detailsUrl = '@Url.Action("Details", "Keg", new { id = "__id__" })'.replace('__id__', item.id);
                                const bestBeforeDate = new Date(item.bestBefore);
                                const isExpiring = bestBeforeDate <= threshold;
                                const rowClass = isExpiring ? 'row-expiring' : '';

                                const rowHtml = `
                                    <tr class="${rowClass}">
                                        <td>${item.slCode}</td>
                                        <td>${item.beerStyleName || '-'}</td>
                                        <td>${item.volumeInLitres} L</td>
                                        <td>${item.materialDisplay}</td>
                                        <td>${item.headTypeDisplay}</td>
                                        <td>${item.lastInspectionDisplay}</td>
                                        <td>${item.bestBeforeDisplay}</td>
                                        <td><a href="${detailsUrl}" class="bw-pill-link">Details</a></td>
                                    </tr>`;

                                $tableBody.append(rowHtml);
                            });
                        }
                    });
                }, 300);
            });
        });
    </script>
}
