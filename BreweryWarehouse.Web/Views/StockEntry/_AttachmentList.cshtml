@model IEnumerable<BreweryWarehouse.Model.Attachment>

@if (!Model.Any())
{
    <p class="bw-text-muted bw-attachments-empty">
        No attachments yet.
    </p>
}
else
{
    <table class="bw-table bw-attachments-table">
        <thead>
            <tr>
                <th>File</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>
                        <a href="@a.FilePath" target="_blank" class="bw-link">
                            @a.FileName
                        </a>
                    </td>
                    <td>@(Math.Round(a.FileSize / 1024.0, 1)) KB</td>
                    <td>@a.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        <button type="button"
                                class="bw-btn bw-btn-danger"
                                onclick="deleteAttachment(@a.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
