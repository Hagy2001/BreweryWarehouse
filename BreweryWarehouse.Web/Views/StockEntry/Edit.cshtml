@model BreweryWarehouse.Web.Models.StockEntryEditModel

@{
    ViewData["Title"] = "Edit Stock Entry";
    ViewData["Culture"] = "hr";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="StockEntry" asp-action="Index">Stock</a></li>
        <li><a asp-action="Details" asp-route-id="@Model.Id">Entry @Model.Id</a></li>
        <li aria-current="page">Edit</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Edit Entry @Model.Id</h1>
</div>

<div class="detail-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_CreateOrEdit" model="@(new BreweryWarehouse.Web.Models.StockEntryCreateModel
        {
            ContainerId = Model.ContainerId,
            LocationId = Model.LocationId,
            Quantity = Model.Quantity,
            DateReceived = Model.DateReceived,
            Notes = Model.Notes
        })" />
    </form>
</div>
