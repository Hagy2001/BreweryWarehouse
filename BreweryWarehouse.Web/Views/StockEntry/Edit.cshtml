@model BreweryWarehouse.Web.Models.StockEntryEditModel

@{
    ViewData["Title"] = "Edit Stock Entry";
    ViewData["Culture"] = "hr";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="StockEntry" asp-action="Index">Stock</a></li>
        <li><a asp-action="Details" asp-route-id="@Model.Id">Entry @Model.Id</a></li>
        <li aria-current="page">Edit</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Edit Entry @Model.Id</h1>
</div>

<div class="detail-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_CreateOrEdit" model="@(new BreweryWarehouse.Web.Models.StockEntryCreateModel
        {
            ContainerId = Model.ContainerId,
            LocationId = Model.LocationId,
            Quantity = Model.Quantity,
            DateReceived = Model.DateReceived,
            Notes = Model.Notes
        })" />
    </form>
</div>

<div class="bw-card bw-attachments-section">
    <h3 class="bw-card__title">Attachments</h3>
    <p class="bw-text-muted">
        Attach delivery receipts, invoices or quality control documents.
        Upload is optional.
    </p>

    <form id="attachmentDropzone"
          action="/stock-entries/@Model.Id/upload"
          class="dropzone"
          enctype="multipart/form-data">
    </form>

    <div id="attachmentList"></div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/lib/dropzone/dropzone.min.css" />
    <script src="~/lib/dropzone/dropzone.min.js"></script>

    <script>
        Dropzone.autoDiscover = false;

        var dz = new Dropzone("#attachmentDropzone", {
            paramName: "file",
            maxFilesize: 20,
            addRemoveLinks: false,
            dictDefaultMessage: "Drop files here or click to upload",
            success: function (file, response) {
                this.removeFile(file);
                loadAttachments();
            },
            error: function (file, message) {
                alert("Upload failed: " + message);
                this.removeFile(file);
            }
        });

        function loadAttachments() {
            $("#attachmentList").load("/stock-entries/@Model.Id/attachments");
        }

        function deleteAttachment(id) {
            if (!confirm("Delete this attachment?")) return;
            $.ajax({
                url: "/stock-entries/attachments/" + id + "/delete",
                method: "POST",
                headers: {
                    "RequestVerificationToken":
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function () { loadAttachments(); },
                error: function () { alert("Delete failed."); }
            });
        }

        $(function () { loadAttachments(); });
    </script>
}
