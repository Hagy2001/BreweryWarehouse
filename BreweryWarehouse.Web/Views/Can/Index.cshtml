@model List<BreweryWarehouse.Model.Can>

@{
    ViewData["Title"] = "Cans";
    DateTime expiryThreshold = DateTime.Today.AddDays(30);
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li aria-current="page">Cans</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Cans</h1>
    <div class="bw-page-actions">
        <a asp-controller="Can" asp-action="Create" class="bw-btn bw-btn-primary">New Can</a>
    </div>
</div>

<div class="bw-toolbar">
    <input type="text" id="canSearch" class="bw-input" placeholder="Search by SL code or beer style" autocomplete="off" />
</div>

<div class="bw-table-wrap">
    <table class="bw-table">
        <thead>
            <tr>
                <th>SLCode</th>
                <th>Beer Style</th>
                <th>Size</th>
                <th>Barcode</th>
                <th>Packaging Date</th>
                <th>Best Before</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody id="canTableBody">
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var can in Model)
                {
                    bool isExpiringSoon = can.BestBefore.Date <= expiryThreshold;
                    string sizeDisplay = can.Size switch
                    {
                        BreweryWarehouse.Model.CanSize.Can033 => "0.33 L",
                        BreweryWarehouse.Model.CanSize.Can044 => "0.44 L",
                        _ => can.Size.ToString()
                    };

                    <tr class="@(isExpiringSoon ? "row-expiring" : string.Empty)">
                        <td>@can.SLCode</td>
                        <td>@can.BeerStyle?.Name</td>
                        <td>@sizeDisplay</td>
                        <td>@can.Barcode</td>
                        <td>@can.PackagingDate.ToString("dd MMM yyyy")</td>
                        <td>@can.BestBefore.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-controller="Can" asp-action="Details" asp-route-id="@can.Id" class="bw-pill-link">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            let searchTimer = null;
            const $searchInput = $('#canSearch');
            const $tableBody = $('#canTableBody');

            $searchInput.on('keyup', function () {
                clearTimeout(searchTimer);
                const query = $(this).val();

                searchTimer = setTimeout(function () {
                    $.ajax({
                        url: '@Url.Action("Search", "Can")',
                        type: 'GET',
                        data: { q: query },
                        success: function (data) {
                            $tableBody.empty();

                            if (!data || data.length === 0) {
                                $tableBody.append('<tr><td colspan="7">No results found.</td></tr>');
                                return;
                            }

                            const threshold = new Date();
                            threshold.setDate(threshold.getDate() + 30);

                            data.forEach(function (item) {
                                const detailsUrl = '@Url.Action("Details", "Can", new { id = "__id__" })'.replace('__id__', item.id);
                                const bestBeforeDate = new Date(item.bestBefore);
                                const isExpiring = bestBeforeDate <= threshold;
                                const rowClass = isExpiring ? 'row-expiring' : '';

                                const rowHtml = `
                                    <tr class="${rowClass}">
                                        <td>${item.slCode}</td>
                                        <td>${item.beerStyleName}</td>
                                        <td>${item.sizeDisplay}</td>
                                        <td>${item.barcode}</td>
                                        <td>${item.packagingDateDisplay}</td>
                                        <td>${item.bestBeforeDisplay}</td>
                                        <td><a href="${detailsUrl}" class="bw-pill-link">Details</a></td>
                                    </tr>`;

                                $tableBody.append(rowHtml);
                            });
                        }
                    });
                }, 300);
            });
        });
    </script>
}
