@model BreweryWarehouse.Web.Models.CanEditModel

@{
    ViewData["Culture"] = "hr";
    ViewData["Title"] = $"Edit {Model.SLCode}";
}

<nav aria-label="breadcrumb" class="bw-breadcrumb-nav">
    <ol class="bw-breadcrumb">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Can" asp-action="Index">Cans</a></li>
        <li><a asp-action="Details" asp-route-id="@Model.Id">@Model.SLCode</a></li>
        <li aria-current="page">Edit</li>
    </ol>
</nav>

<div class="bw-page-header">
    <h1 class="bw-page-title">Edit @Model.SLCode</h1>
</div>

<div class="detail-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @await Html.PartialAsync("_CreateOrEdit", new BreweryWarehouse.Web.Models.CanCreateModel 
        { 
            SLCode = Model.SLCode, 
            PackagingDate = Model.PackagingDate, 
            BestBefore = Model.BestBefore, 
            Size = Model.Size, 
            Barcode = Model.Barcode,
            BeerStyleId = Model.BeerStyleId,
            BeerStyleName = Model.BeerStyleName
        })
    </form>
</div>